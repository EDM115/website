  },
  "scripts": {
    "analyze": "pnpm prebuild && nuxt analyze",
    "build": "pnpm prebuild && nuxt build",
    "build:blog": "jiti generate-blog-data.script.ts && node -e \"console.log('📝 Generating docfind indexes for blog posts...')\" && docfind docfind/blog.json docfind/blog && node -e \"console.log('');console.log('📝 Generating docfind indexes for telegram posts...')\" && docfind docfind/telegram.json docfind/telegram && jiti post.generate-blog-data.script.ts",
    "build:projects": "jiti generate-projects-data.script.ts",
    "build:wasm": "asc assembly/polychrome_effect.ts --target release -Ospeed -Osize --converge --noAssert -o public/polychrome/effect.wasm && asc assembly/polychrome_effect_alt.ts --target release -Ospeed -Osize --converge --noAssert -o public/polychrome/effect_alt.wasm",
    "cleanup": "nuxt cleanup",
    "cli:count-words": "jiti read-time.cli.script.ts",
    "dev": "nuxt dev --no-clear",
    "dev:expose:global": "nuxt dev --no-clear --tunnel",
    "dev:expose:local": "nuxt dev --no-clear --public",
    "format": "eslint -c eslint.stylistic.config.ts --concurrency=auto --fix .",
    "generate": "pnpm prebuild && nuxt generate",
    "install-docfind:linux": "curl -fsSL https://microsoft.github.io/docfind/install.sh | sh",
    "install-docfind:windows": "irm https://microsoft.github.io/docfind/install.ps1 | iex",
    "lint": "pnpm run \"/^lint:eslint|^lint:oxlint/\"",
    "lint:eslint": "eslint --cache --cache-location .eslintcache --concurrency=auto .",
    "lint:fix": "pnpm run \"/^lint:fix:.*/\"",
    "lint:fix:eslint": "eslint --concurrency=auto --fix .",
    "lint:fix:oxlint": "oxlint --fix",
    "lint:oxlint": "oxlint",
    "prebuild": "pnpm build:wasm && pnpm build:blog && pnpm build:projects",
    "preview": "nuxt preview --port 8000",
    "start:ssg": "pnpm dlx serve .output/public -p 8000 -s",
    "start:ssr": "node .output/server/index.mjs",
    "typecheck": "nuxt typecheck"
  },
  "type": "module",
  "version": "2.16.1"
}
